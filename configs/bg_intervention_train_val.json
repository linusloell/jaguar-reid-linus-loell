{
    "run_name": "bg_intervention_train_val",
    "data_dir": "data/challenge1",
    "checkpoint_dir": "checkpoints",
    "model": "facebook/dinov3-vitl16-pretrain-lvd1689m",
    "model_family": "dinov3",
    "input_size": 244,
    "embedding_dim": 256,
    "hidden_dim": 512,
    "loss_type": "arcface",
    "focal_alpha": 0.25,
    "focal_gamma": 2.0,
    "focal_reduction": "mean",
    "arcface_margin": 0.5,
    "arcface_scale": 64.0,
    "sphere_m": 4,
    "sphere_scale": 64.0,
    "dropout": 0.3,
    "batch_size": 32,
    "learning_rate": 3e-4,
    "lr_scheduler_type": "cosine_warmup",
    "lr_scheduler_warmup_epochs": 5,
    "lr_scheduler_eta_min": 5e-7,
    "weight_decay": 1e-4,
    "num_epochs": 70,
    "patience": 10,
    "val_split": 0.2,
    "seed": 42,
    "train_bg_intervention": "noise",
    "val_bg_intervention": "noise"
}