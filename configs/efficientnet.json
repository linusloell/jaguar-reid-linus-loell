{
    "run_name": "efficientnet-b7-arcface",
    "data_dir": "data",
    "checkpoint_dir": "checkpoints",
    "model": "google/efficientnet-b7",
    "model_family": "efficientnet",
    "input_size": 244,
    "embedding_dim": 256,
    "hidden_dim": 512,
    "loss_type": "arcface",
    "focal_alpha": 0.25,
    "focal_gamma": 2.0,
    "focal_reduction": "mean",
    "arcface_margin": 0.5,
    "arcface_scale": 64.0,
    "sphere_m": 4,
    "sphere_scale": 64.0,
    "dropout": 0.3,
    "batch_size": 32,
    "learning_rate": 1e-4,
    "lr_scheduler_type": "reduce_on_plateau",
    "weight_decay": 1e-4,
    "num_epochs": 50,
    "patience": 10,
    "val_split": 0.2,
    "seed": 42
}
