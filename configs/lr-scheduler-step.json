{
    "run_name": "lr-scheduler-step",
    "data_dir": "data",
    "checkpoint_dir": "checkpoints",
    "model": "hf-hub:BVRA/MegaDescriptor-L-384",
    "input_size": 384,
    "embedding_dim": 256,
    "hidden_dim": 512,
    "loss_type": "arcface",
    "focal_alpha": 0.25,
    "focal_gamma": 2.0,
    "focal_reduction": "mean",
    "arcface_margin": 0.5,
    "arcface_scale": 64.0,
    "sphere_m": 4,
    "sphere_scale": 64.0,
    "dropout": 0.3,
    "batch_size": 32,
    "learning_rate": 1e-4,
    "lr_scheduler_type": "step",
    "lr_eta_min": 1e-6,
    "weight_decay": 1e-4,
    "num_epochs": 50,
    "patience": 10,
    "val_split": 0.2,
    "seed": 42
}